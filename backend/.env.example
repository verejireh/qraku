# QRaku Backend — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 채우세요.
# .env 는 절대 커밋하지 않습니다 (.gitignore 확인).

# ── 데이터베이스 ────────────────────────────────────────────────
# Option A: MySQL (현 운영)
DATABASE_URL=mysql+aiomysql://user:password@localhost/qraku
# Option B: PostgreSQL (DBM-12 컷오버 후 아래 줄로 교체)
# DATABASE_URL=postgresql+asyncpg://qraku:***@localhost:5432/qraku

# ── Redis (INF-01) ─────────────────────────────────────────────
# 로컬 개발: redis://localhost:6379/0
# 운영:      운영 Redis 인스턴스 URL (OPR-05 참고)
REDIS_URL=redis://localhost:6379/0

# ── Dramatiq broker (OPS-02) ──────────────────────────────────
# 미설정 시 REDIS_URL을 그대로 사용. 별도 인스턴스 분리 시에만 명시.
# DRAMATIQ_BROKER_URL=redis://localhost:6379/1

# ── 멱등성 (INF-03) ────────────────────────────────────────────
# Idempotency-Key 결과 캐시 보존 기간 (초). 기본 86400 = 24시간
IDEMPOTENCY_TTL_SECONDS=86400

# ── 인증 ───────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string

# ── 암호화 (Fernet) ────────────────────────────────────────────
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️  운영 후 변경 금지 — 기존 암호화 데이터 복호화 불가
ENCRYPTION_KEY=

# ── Square ─────────────────────────────────────────────────────
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox

# ── PayPay ─────────────────────────────────────────────────────
# Webhook 서명 검증용 시크릿 (PAY-01 완료 후 PayPay 콘솔에서 발급)
PAYPAY_WEBHOOK_SECRET=

# ── Stripe (구독) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_SIXMONTH_PRICE_ID=
STRIPE_YEARLY_PRICE_ID=
STRIPE_MONTHLY_OPEN_PRICE_ID=
STRIPE_SIXMONTH_OPEN_PRICE_ID=
STRIPE_YEARLY_OPEN_PRICE_ID=

# ── AI / 외부 서비스 ───────────────────────────────────────────
GEMINI_API_KEY=
VISION_API_KEY=

# ── 프론트엔드 연동 ────────────────────────────────────────────
# PayPay 콜백 URL 구성에 사용
FRONTEND_BASE_URL=https://qraku.com

# ── CORS ───────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://qraku.com,https://www.qraku.com
